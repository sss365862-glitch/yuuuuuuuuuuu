<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>友情時効裁判所 - Friendship Court</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Shippori Mincho', serif; background: #0f172a; color: #e2e8f0; }
        .gavel-anim { animation: shake 0.5s ease-in-out infinite; }
        @keyframes shake { 0%, 100% { transform: rotate(0deg); } 25% { transform: rotate(-20deg); } 75% { transform: rotate(20deg); } }
        .parchment { background: #f3e5ab; color: #2d2d2d; border: 2px solid #b8860b; box-shadow: 0 0 20px rgba(0,0,0,0.5); }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center p-4">

    <header class="text-center my-8">
        <h1 class="text-4xl font-bold text-yellow-600 mb-2">⚖️ 友情時効裁判所</h1>
        <p class="text-slate-400">数年前の「どっちが悪かったか」に、AIが終止符を打つ。</p>
    </header>

    <main class="w-full max-w-4xl grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-slate-800 p-6 rounded-lg border-l-4 border-blue-500">
            <h2 class="text-xl mb-4 text-blue-400 font-bold">原告 (言い出す側)</h2>
            <textarea id="plaintiff" class="w-full h-32 p-3 bg-slate-900 rounded border border-slate-700 focus:outline-none focus:border-blue-500" placeholder="例：3年前、旅行中に勝手に私のプリンを食べた。"></textarea>
        </div>

        <div class="bg-slate-800 p-6 rounded-lg border-l-4 border-red-500">
            <h2 class="text-xl mb-4 text-red-400 font-bold">被告 (言い返したい側)</h2>
            <textarea id="defendant" class="w-full h-32 p-3 bg-slate-900 rounded border border-slate-700 focus:outline-none focus:border-red-500" placeholder="例：名前が書いてなかったし、賞味期限が当日だった。"></textarea>
        </div>
    </main>

    <div class="mt-8 flex gap-4">
        <button onclick="setSampleData()" class="px-6 py-2 bg-slate-700 hover:bg-slate-600 rounded-full transition">デモ用データ</button>
        <button onclick="startTrial()" id="trial-btn" class="px-12 py-4 bg-yellow-700 hover:bg-yellow-600 text-white font-bold rounded-full text-xl shadow-lg transform hover:scale-105 transition">⚖️ 審 理 開 廷</button>
    </div>

    <div id="loading" class="hidden fixed inset-0 bg-black/80 flex flex-col items-center justify-center z-50">
        <div class="text-6xl mb-4 gavel-anim">🔨</div>
        <p class="text-2xl text-yellow-500 animate-pulse">証拠を精査中...</p>
    </div>

    <div id="result-modal" class="hidden fixed inset-0 bg-black/90 flex items-center justify-center p-4 z-50">
        <div class="parchment max-w-2xl w-full p-8 rounded-sm relative overflow-y-auto max-h-[90vh]">
            <div class="text-center border-b-2 border-yellow-900/20 pb-4 mb-6">
                <h2 class="text-3xl font-black text-yellow-900">判 決 宣告</h2>
            </div>
            <div id="verdict-content" class="space-y-6 text-lg leading-relaxed">
                </div>
            <button onclick="closeModal()" class="mt-8 w-full py-3 bg-yellow-900 text-white rounded hover:bg-yellow-800 font-bold">閉廷</button>
        </div>
    </div>

    <script>
        const API_KEY = 'YOUR_OPENAI_API_KEY'; // ※ハッカソン用。提出時は削除するか環境変数へ

        async function startTrial() {
            const plaintiff = document.getElementById('plaintiff').value;
            const defendant = document.getElementById('defendant').value;
            if (!plaintiff || !defendant) return alert("両者の主張を入力してください");

            document.getElementById('loading').classList.remove('hidden');

            const prompt = `
            あなたは友情時効裁判所の厳格かつユーモア溢れる最高裁判事です。
            以下の喧嘩の内容を分析し、JSON形式で判決を下してください。
            【原告の主張】: ${plaintiff}
            【被告の主張】: ${defendant}

            返却フォーマット:
            {
                "verdict": "主文(例：被告は有罪、ただし執行猶予とする)",
                "reason": "判決の理由(法的な専門用語とユーモアを混ぜて)",
                "statute_of_limitations": "時効かどうか(例：友情時効により消滅)",
                "reconciliation": "友情継続のための命令(例：被告は原告に寿司を奢ること)"
            }`;

            try {
                const response = await fetch('https://api.openai.com/v1/chat/completions', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${API_KEY}`
                    },
                    body: JSON.stringify({
                        model: "gpt-4o",
                        messages: [{ role: "system", content: "あなたは裁判官です。JSONのみで回答してください。" }, { role: "user", content: prompt }],
                        response_format: { type: "json_object" }
                    })
                });

                const data = await response.json();
                const result = JSON.parse(data.choices[0].message.content);
                showResult(result);
            } catch (error) {
                console.error(error);
                alert("審議に失敗しました。");
            } finally {
                document.getElementById('loading').classList.add('hidden');
            }
        }

        function showResult(res) {
            const content = document.getElementById('verdict-content');
            content.innerHTML = `
                <div><span class="font-bold text-red-800">【主文】</span><br>${res.verdict}</div>
                <div><span class="font-bold text-yellow-900">【理由】</span><br>${res.reason}</div>
                <div><span class="font-bold text-yellow-900">【時効判断】</span><br>${res.statute_of_limitations}</div>
                <div class="bg-yellow-600/10 p-4 border-2 border-dashed border-yellow-800">
                    <span class="font-bold text-green-800">【友情継続命令】</span><br>${res.reconciliation}
                </div>
            `;
            document.getElementById('result-modal').classList.remove('hidden');
            
            // 音声読み上げ
            const speech = new SpeechSynthesisUtterance(`判決宣告。主文、${res.verdict}。理由は、${res.reason}`);
            speech.lang = 'ja-JP';
            speech.rate = 0.9;
            window.speechSynthesis.speak(speech);
        }

        function setSampleData() {
            document.getElementById('plaintiff').value = "2021年のBBQにて、私が焼いていた高級肉を、目を離した隙に全部食べられた。";
            document.getElementById('defendant').value = "網の上で放置されて焦げそうだった。これは肉に対する救済処置であり、窃盗ではない。";
        }

        function closeModal() {
            document.getElementById('result-modal').classList.add('hidden');
            window.speechSynthesis.cancel();
        }
    </script>
</body>
</html>
